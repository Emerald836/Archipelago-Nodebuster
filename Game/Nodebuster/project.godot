; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Nodebuster"
run/main_scene="res://MainScene.tscn"
config/use_custom_user_dir=true
config/features=PackedStringArray("4.2", "Mobile")
boot_splash/show_image=false
config/icon="res://icon.svg"
config/windows_native_icon="res://Icon.ico"

[autoload]

ModLoaderStore="*res://addons/mod_loader/mod_loader_store.gd"
ModLoader="*res://addons/mod_loader/mod_loader.gd"
Layers="*res://Scripts/Autoloads/Layers.gd"
Defer="*res://Scripts/Autoloads/Defer.gd"
Refs="*res://Scripts/Autoloads/Refs.gd"
Saver="*res://Scripts/Autoloads/Saver.gd"
UpgradeStore="*res://Scripts/Autoloads/Stores/UpgradeStore.gd"
MilestoneStore="*res://Scripts/Autoloads/Stores/MilestoneStore.gd"
Globals="*res://Scripts/Autoloads/Globals.gd"
Springer="*res://Scripts/Autoloads/Springer.gd"
Jumper="*res://Scripts/Autoloads/Jumper.gd"
Shaker="*res://Scripts/Autoloads/Shaker.gd"
MyTimer="*res://Scripts/Autoloads/Timer/MyTimer.gd"
ShapeCaster="*res://Scripts/Autoloads/ShapeCaster.gd"
Effects="*res://Scripts/Autoloads/Effects.gd"
State="*res://Scripts/Autoloads/State.gd"
SFX="*res://Scripts/Autoloads/SFX.gd"
BGM="*res://Scripts/Autoloads/BGM.gd"
OptionData="*res://Scripts/Autoloads/OptionData.gd"
RTLSizer="*res://Scripts/Autoloads/RTLSizer.gd"
MySteam="*res://Scripts/Autoloads/MySteam.gd"

[debug]

file_logging/enable_file_logging=true

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/resizable=false
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[editor]

naming/scene_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/mod_loader/_export_plugin/plugin.cfg", "res://addons/mod_tool/plugin.cfg")

[gui]

common/snap_controls_to_pixels=false
theme/custom="res://Themes/DefaultTheme.tres"

[input]

lmb={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":false,"double_click":false,"script":null)
